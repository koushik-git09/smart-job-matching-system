# Backend environment variables (copy to backend/.env and fill in)
# IMPORTANT: never commit backend/.env

# Auth (REQUIRED in production)
# Generate a long random secret for JWT signing.
# Example (PowerShell): python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=oRpeT7SVtR8p4c7CD7RUf2fXcPiZ45yteqMxSKrkfTSSBmjzaSvEXY0Y9TdVtQMX

# CORS (REQUIRED in production)
# Comma-separated list of allowed frontend origins.
# Example: https://your-app.vercel.app,https://your-app-git-main-yourteam.vercel.app
CORS_ALLOW_ORIGINS=http://localhost:5173

# Optional: allow via regex (handy for Vercel preview deployments)
# Example: ^https://.*\.vercel\.app$
# CORS_ALLOW_ORIGIN_REGEX=

# Firebase Admin SDK (REQUIRED unless you bundle a key file)
# Preferred: set ONE of these in your hosting environment.
# 1) Raw JSON content:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# 2) Base64 JSON:
# FIREBASE_SERVICE_ACCOUNT_B64=

# NLP
SPACY_MODEL=en_core_web_sm

# Optional (downloads at runtime; keep off on small instances)
ENABLE_BERT_NER=0
# BERT_NER_MODEL=dslim/bert-base-NER

# Email sending
EMAIL_BACKEND=smtp

# Gmail SMTP sender account
# EMAIL_USER=yourgmail@gmail.com
# EMAIL_PASS=your-google-app-password   # App Password (requires 2-Step Verification)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_STARTTLS=true

# Optional
SMTP_TIMEOUT=20
# EMAIL_FROM=yourgmail@gmail.com

# Dev-only (no real email):
# EMAIL_BACKEND=console
