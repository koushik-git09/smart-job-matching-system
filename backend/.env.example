# Backend environment variables (example)
# Copy to backend/.env for local dev only. Do NOT commit backend/.env.

# --- CORS ---
# Comma-separated list of allowed browser origins.
# Set this on Render to your Vercel site origin.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: regex for Vercel preview deployments, e.g.
# CORS_ALLOW_ORIGIN_REGEX=^https://.*\.vercel\.app$

# --- Firebase / Firestore ---
# Provide ONE of these in production (Render):
# 1) FIREBASE_SERVICE_ACCOUNT_JSON: raw service account JSON
# 2) FIREBASE_SERVICE_ACCOUNT_B64: base64-encoded service account JSON
# 3) GOOGLE_APPLICATION_CREDENTIALS: path to service account file on disk
#
# FIREBASE_SERVICE_ACCOUNT_B64=

# --- Email (optional; recruiter contact) ---
EMAIL_BACKEND=console
# EMAIL_USER=
# EMAIL_PASS=
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
